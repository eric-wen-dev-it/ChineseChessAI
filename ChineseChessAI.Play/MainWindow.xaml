<Window x:Class="ChineseChessAI.Play.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="中国象棋智能体对弈"
        Width="1180"
        Height="760"
        MinWidth="960"
        MinHeight="680"
        Background="#F4EFE2">
    <Window.Resources>
        <Style x:Key="ChessPieceStyle" TargetType="Button">
            <Setter Property="Background" Value="#F5F5DC" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Ellipse x:Name="OuterCircle"
                                     Fill="{TemplateBinding Background}"
                                     Stroke="#5D4037"
                                     StrokeThickness="2" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                            <Rectangle x:Name="HighlightBox"
                                       Margin="-2"
                                       StrokeThickness="3"
                                       Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Content" Value="">
                                <Setter TargetName="OuterCircle" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="HighlightBox" Property="Visibility" Value="Visible" />
                                <Setter TargetName="HighlightBox" Property="Stroke" Value="#FF9800" />
                            </Trigger>
                            <Trigger Property="Tag" Value="Legal">
                                <Setter TargetName="HighlightBox" Property="Visibility" Value="Visible" />
                                <Setter TargetName="HighlightBox" Property="Stroke" Value="#D4AF37" />
                            </Trigger>
                            <Trigger Property="Tag" Value="From">
                                <Setter TargetName="HighlightBox" Property="Visibility" Value="Visible" />
                                <Setter TargetName="HighlightBox" Property="Stroke" Value="#FF4500" />
                            </Trigger>
                            <Trigger Property="Tag" Value="To">
                                <Setter TargetName="HighlightBox" Property="Visibility" Value="Visible" />
                                <Setter TargetName="HighlightBox" Property="Stroke" Value="#00C853" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <Viewbox Grid.Column="0"
                 Margin="4"
                 Stretch="Uniform">
            <Border Width="600"
                    Height="660"
                    Background="#D2B48C"
                    BorderBrush="#5D4037"
                    BorderThickness="4"
                    CornerRadius="2">
                <Grid Margin="10">
                    <Canvas x:Name="ChessLinesCanvas"
                            IsHitTestVisible="False" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False">
                        <TextBlock Margin="0,0,120,0"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#5D4037"
                                   Opacity="0.4"
                                   Text="Chu He" />
                        <TextBlock FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#5D4037"
                                   Opacity="0.4"
                                   Text="Han Jie" />
                    </StackPanel>
                    <UniformGrid x:Name="BoardGrid"
                                 Rows="10"
                                 Columns="9"
                                 Background="Transparent" />
                </Grid>
            </Border>
        </Viewbox>

        <StackPanel Grid.Column="2">
            <TextBlock Text="中国象棋智能体对弈"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#3A2613" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#5E4A36"
                       Text="红方和黑方都选智能体后，点击开始对弈即可自动走完整局。" />

            <Grid Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Margin="0,0,0,6"
                               FontWeight="SemiBold"
                               Text="红方" />
                    <ComboBox x:Name="RedPlayerComboBox"
                              Height="30"
                              SelectedIndex="0"
                              SelectionChanged="OnPlayerTypeChanged">
                        <ComboBoxItem Content="Human（手动）" />
                        <ComboBoxItem Content="MCTS" />
                        <ComboBoxItem Content="Traditional（传统搜索）" />
                        <ComboBoxItem Content="Pikafish" />
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Margin="0,0,0,6"
                               FontWeight="SemiBold"
                               Text="黑方" />
                    <ComboBox x:Name="BlackPlayerComboBox"
                              Height="30"
                              SelectedIndex="2"
                              SelectionChanged="OnPlayerTypeChanged">
                        <ComboBoxItem Content="Human（手动）" />
                        <ComboBoxItem Content="MCTS" />
                        <ComboBoxItem Content="Traditional（传统搜索）" />
                        <ComboBoxItem Content="Pikafish" />
                    </ComboBox>
                </StackPanel>
            </Grid>

            <Border Margin="0,12,0,0"
                    Padding="10"
                    Background="#FFF8EC"
                    BorderBrush="#D5C2A1"
                    BorderThickness="1"
                    CornerRadius="6">
                <TextBlock Foreground="#543A1F"
                           TextWrapping="Wrap"
                           Text="智能体对弈：红方和黑方都不要选 Human。MCTS 需要模型文件，Pikafish 需要 exe，Traditional 可直接运行。开始后程序会自动轮流走棋。" />
            </Border>

            <TextBlock x:Name="RedMctsModelFileLabel"
                       Margin="0,14,0,6"
                       FontWeight="SemiBold"
                       Text="红方 MCTS 模型文件" />
            <DockPanel x:Name="RedMctsModelFilePanel"
                       LastChildFill="False">
                <TextBox x:Name="RedMctsModelPathTextBox"
                         Width="270"
                         Height="30"
                         VerticalContentAlignment="Center" />
                <Button Width="74"
                        Height="30"
                        Margin="8,0,0,0"
                        Click="OnBrowseRedMctsModelClick"
                        Content="浏览" />
            </DockPanel>

            <TextBlock x:Name="BlackMctsModelFileLabel"
                       Margin="0,12,0,6"
                       FontWeight="SemiBold"
                       Text="黑方 MCTS 模型文件" />
            <DockPanel x:Name="BlackMctsModelFilePanel"
                       LastChildFill="False">
                <TextBox x:Name="BlackMctsModelPathTextBox"
                         Width="270"
                         Height="30"
                         VerticalContentAlignment="Center" />
                <Button Width="74"
                        Height="30"
                        Margin="8,0,0,0"
                        Click="OnBrowseBlackMctsModelClick"
                        Content="浏览" />
            </DockPanel>

            <TextBlock x:Name="PikafishFileLabel"
                       Margin="0,12,0,6"
                       FontWeight="SemiBold"
                       Text="Pikafish 引擎 exe" />
            <DockPanel x:Name="PikafishFilePanel"
                       LastChildFill="False">
                <TextBox x:Name="PikafishPathTextBox"
                         Width="270"
                         Height="30"
                         VerticalContentAlignment="Center" />
                <Button Width="74"
                        Height="30"
                        Margin="8,0,0,0"
                        Click="OnBrowsePikafishClick"
                        Content="浏览" />
            </DockPanel>

            <Grid Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="2">
                    <TextBlock x:Name="SearchBudgetLabel"
                               Margin="0,0,0,6"
                               FontWeight="SemiBold"
                               Text="模拟次数 / 深度" />
                    <TextBox x:Name="SimulationsTextBox"
                             Height="30"
                             VerticalContentAlignment="Center"
                             Text="2400" />
                </StackPanel>
            </Grid>

            <WrapPanel Margin="0,16,0,0">
                <Button x:Name="NewGameButton"
                        Width="110"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="OnNewGameClick"
                        Content="开始对弈" />
                <Button x:Name="AiMoveButton"
                        Width="110"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="OnAiMoveClick"
                        Content="继续 AI" />
                <Button x:Name="TraditionalDemoButton"
                        Width="110"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="OnTraditionalDemoClick"
                        Content="传统演示" />
                <Button x:Name="ResignButton"
                        Width="110"
                        Height="34"
                        Click="OnResignClick"
                        Content="认输" />
            </WrapPanel>

            <Border Margin="0,18,0,0"
                    Padding="12"
                    Background="#FFF8EC"
                    BorderBrush="#D5C2A1"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Text="状态" />
                    <TextBlock x:Name="StatusTextBlock"
                               Margin="0,6,0,0"
                               Foreground="#543A1F"
                               Text="选择红方和黑方后开始对弈。" />
                    <TextBlock x:Name="TurnTextBlock"
                               Margin="0,8,0,0"
                               Foreground="#543A1F" />
                    <TextBlock x:Name="SideTextBlock"
                               Margin="0,4,0,0"
                               Foreground="#543A1F" />
                </StackPanel>
            </Border>

            <TextBlock Margin="0,18,0,6"
                       FontWeight="SemiBold"
                       Text="棋谱" />
            <TextBox x:Name="MoveHistoryTextBox"
                     Height="90"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />

            <TextBlock Margin="0,18,0,6"
                       FontWeight="SemiBold"
                       Text="日志" />
            <TextBox x:Name="LogBox"
                     Height="240"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     AcceptsReturn="True" />
        </StackPanel>
    </Grid>
</Window>
