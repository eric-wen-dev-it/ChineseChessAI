<Window x:Class="ChineseChessAI.Play.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chinese Chess Play"
        Width="1180"
        Height="760"
        MinWidth="960"
        MinHeight="680"
        Background="#F4EFE2">
    <Window.Resources>
        <Style x:Key="ChessPieceStyle" TargetType="Button">
            <Setter Property="Background" Value="#F5F5DC" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Ellipse x:Name="OuterCircle"
                                     Fill="{TemplateBinding Background}"
                                     Stroke="#5D4037"
                                     StrokeThickness="2" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                            <Rectangle x:Name="HighlightBox"
                                       Margin="-2"
                                       StrokeThickness="3"
                                       Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Content" Value="">
                                <Setter TargetName="OuterCircle" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="HighlightBox" Property="Visibility" Value="Visible" />
                                <Setter TargetName="HighlightBox" Property="Stroke" Value="#FF9800" />
                            </Trigger>
                            <Trigger Property="Tag" Value="Legal">
                                <Setter TargetName="HighlightBox" Property="Visibility" Value="Visible" />
                                <Setter TargetName="HighlightBox" Property="Stroke" Value="#D4AF37" />
                            </Trigger>
                            <Trigger Property="Tag" Value="From">
                                <Setter TargetName="HighlightBox" Property="Visibility" Value="Visible" />
                                <Setter TargetName="HighlightBox" Property="Stroke" Value="#FF4500" />
                            </Trigger>
                            <Trigger Property="Tag" Value="To">
                                <Setter TargetName="HighlightBox" Property="Visibility" Value="Visible" />
                                <Setter TargetName="HighlightBox" Property="Stroke" Value="#00C853" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <Viewbox Grid.Column="0"
                 Margin="4"
                 Stretch="Uniform">
            <Border Width="600"
                    Height="660"
                    Background="#D2B48C"
                    BorderBrush="#5D4037"
                    BorderThickness="4"
                    CornerRadius="2">
                <Grid Margin="10">
                    <Canvas x:Name="ChessLinesCanvas"
                            IsHitTestVisible="False" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False">
                        <TextBlock Margin="0,0,120,0"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#5D4037"
                                   Opacity="0.4"
                                   Text="Chu He" />
                        <TextBlock FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#5D4037"
                                   Opacity="0.4"
                                   Text="Han Jie" />
                    </StackPanel>
                    <UniformGrid x:Name="BoardGrid"
                                 Rows="10"
                                 Columns="9"
                                 Background="Transparent" />
                </Grid>
            </Border>
        </Viewbox>

        <StackPanel Grid.Column="2">
            <TextBlock Text="Chinese Chess Play"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#3A2613" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#5E4A36"
                       Text="Separate play app backed by the shared engine project." />

            <TextBlock Margin="0,18,0,6"
                       FontWeight="SemiBold"
                       Text="Model file" />
            <DockPanel LastChildFill="False">
                <TextBox x:Name="ModelPathTextBox"
                         Width="270"
                         Height="30"
                         VerticalContentAlignment="Center" />
                <Button Width="74"
                        Height="30"
                        Margin="8,0,0,0"
                        Click="OnBrowseModelClick"
                        Content="Browse" />
            </DockPanel>

            <Grid Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Margin="0,0,0,6"
                               FontWeight="SemiBold"
                               Text="Human side" />
                    <ComboBox x:Name="HumanSideComboBox"
                              Height="30"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Play Red" />
                        <ComboBoxItem Content="Play Black" />
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Margin="0,0,0,6"
                               FontWeight="SemiBold"
                               Text="Simulations" />
                    <TextBox x:Name="SimulationsTextBox"
                             Height="30"
                             VerticalContentAlignment="Center"
                             Text="2400" />
                </StackPanel>
            </Grid>

            <WrapPanel Margin="0,16,0,0">
                <Button x:Name="NewGameButton"
                        Width="110"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="OnNewGameClick"
                        Content="New Game" />
                <Button x:Name="AiMoveButton"
                        Width="110"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="OnAiMoveClick"
                        Content="AI Move" />
                <Button x:Name="ResignButton"
                        Width="110"
                        Height="34"
                        Click="OnResignClick"
                        Content="认输" />
            </WrapPanel>

            <Border Margin="0,18,0,0"
                    Padding="12"
                    Background="#FFF8EC"
                    BorderBrush="#D5C2A1"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Text="Status" />
                    <TextBlock x:Name="StatusTextBlock"
                               Margin="0,6,0,0"
                               Foreground="#543A1F"
                               Text="Choose a model and start a game." />
                    <TextBlock x:Name="TurnTextBlock"
                               Margin="0,8,0,0"
                               Foreground="#543A1F" />
                    <TextBlock x:Name="SideTextBlock"
                               Margin="0,4,0,0"
                               Foreground="#543A1F" />
                </StackPanel>
            </Border>

            <TextBlock Margin="0,18,0,6"
                       FontWeight="SemiBold"
                       Text="Move history" />
            <TextBox x:Name="MoveHistoryTextBox"
                     Height="90"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />

            <TextBlock Margin="0,18,0,6"
                       FontWeight="SemiBold"
                       Text="Log" />
            <TextBox x:Name="LogBox"
                     Height="240"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     AcceptsReturn="True" />
        </StackPanel>
    </Grid>
</Window>
